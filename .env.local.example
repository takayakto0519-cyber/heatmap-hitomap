# ============================================================
# Supabase 接続設定（ .env.local にコピーして値を入れてください）
# ============================================================
# Supabaseダッシュボード → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co

# Supabaseダッシュボード → Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (任意) サーバーサイド専用。設定しない場合は anon key にフォールバック。
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 管理画面（/admin/review）の合言葉。加藤会長のみが知る値に変更すること。
ADMIN_PASSWORD=changeme
