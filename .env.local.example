# ============================================================
# Supabase 接続設定（ .env.local にコピーして値を入れてください）
# ============================================================
# Supabaseダッシュボード → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co

# Supabaseダッシュボード → Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (任意) サーバーサイド専用。設定しない場合は anon key にフォールバック。
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 管理画面（/admin/review）のパスワード。加藤会長のみが知る値に変更すること。
ADMIN_PASSWORD=changeme

# 外部提携先向けAPI（/api/partner/routes）のAPIキー。契約先ごとに発行して配布する。
PARTNER_API_KEY=changeme-partner-key

# (任意) 新規投稿・通報・新規登録・サーバーエラーをDiscordへ通知する専用チャンネルのWebhook URL。
# news_digest.py（経済ニュース）が使うDISCORD_WEBHOOK_URLとは別チャンネルにすること。
# 取得方法: Discordサーバー設定 → 連携サービス → ウェブフック → 新しいウェブフック → URLをコピー
# HITOMAP_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# (任意) 学校・法人リードの証拠パックをAIで強化する機能（/api/admin/client-leads/[id]/enrich）で使用。
# 未設定でもエラーにはならず、その機能だけが使えなくなる。
# 取得方法: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxx
